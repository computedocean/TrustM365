    {
      "control_id": "oib:win-oib-es-encryption-d-bitlocker-os-disk-v3-7:select-the-encryption-method-for-operating-system-drives",
      "title": "Select the encryption method for operating system drives",
      "recommended_value": "XTS-AES 256-bit",
      "type": "enum",
      "notes": "Maps to BitLocker CSP EncryptionMethod for OS drives. Prefer XTS-AES-256 where supported.",
      "oib_reference": "https://github.com/SkipToTheEndpoint/OpenIntuneBaseline/blob/main/WINDOWS/SETTINGSOUTPUT.md#win-oib-es-encryption-d-bitlocker-os-disk-v3-7",
      "mdm_csp": "./Device/Vendor/MSFT/BitLocker/OS/EncryptionMethod",
      "registry_key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\FVE\\EncryptionMethod",
      "allowed_values": [
        "XTS-AES 256-bit",
        "XTS-AES 128-bit",
        "AES-CBC 256-bit",
        "AES-CBC 128-bit"
      ]
    },
    {
      "control_id": "oib:win-oib-es-encryption-d-bitlocker-os-disk-v3-7:require-device-encryption",
      "title": "Require Device Encryption",
      "recommended_value": true,
      "type": "boolean",
      "notes": "Enables device encryption; may map to Windows Device Encryption on some SKUs.",
      "oib_reference": "https://github.com/SkipToTheEndpoint/OpenIntuneBaseline/blob/main/WINDOWS/SETTINGSOUTPUT.md#win-oib-es-encryption-d-bitlocker-os-disk-v3-7",
      "mdm_csp": "./Device/Vendor/MSFT/BitLocker/RequireDeviceEncryption",
      "registry_key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\FVE\\RequireDeviceEncryption"
    },
    {
      "control_id": "oib:win-oib-es-encryption-d-bitlocker-os-disk-v3-7:configure-tpm-startup",
      "title": "Configure TPM startup",
      "recommended_value": "Require TPM",
      "type": "enum",
      "notes": "Controls TPM startup behaviour. Values are implementation-specific; validate per OS.",
      "oib_reference": "https://github.com/SkipToTheEndpoint/OpenIntuneBaseline/blob/main/WINDOWS/SETTINGSOUTPUT.md#win-oib-es-encryption-d-bitlocker-os-disk-v3-7",
      "mdm_csp": "./Device/Vendor/MSFT/BitLocker/OS/ConfigureTPMStartup",
      "registry_key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\FVE\\TPMStartup",
      "allowed_values": [
        "Require TPM",
        "Do not allow startup PIN with TPM",
        "Do not allow startup key with TPM"
      ]
    },
    {
      "control_id": "oib:win-oib-es-encryption-d-bitlocker-os-disk-v3-7:allow-bitlocker-without-a-compatible-tpm-requires-a-password-or-a-startup-key-on-a-usb-flash-drive",
      "title": "Allow BitLocker without a compatible TPM (requires a password or a startup key on a USB flash drive)",
      "recommended_value": false,
      "type": "boolean",
      "notes": "When false, BitLocker requires TPM; when true, allows use of startup key/password.",
      "oib_reference": "https://github.com/SkipToTheEndpoint/OpenIntuneBaseline/blob/main/WINDOWS/SETTINGSOUTPUT.md#win-oib-es-encryption-d-bitlocker-os-disk-v3-7",
      "mdm_csp": "./Device/Vendor/MSFT/BitLocker/OS/AllowBitLockerWithoutTPM",
      "registry_key": "HKLM\\SOFTWARE\\Policies\\Microsoft\\FVE\\AllowWithoutTPM"
    }
  ],
