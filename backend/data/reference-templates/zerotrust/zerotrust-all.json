[
  {
    "id": "zerotrust-apps",
    "display_name": "ZeroTrust — Application Registrations",
    "metadata": {
      "owner": "zerotrust",
      "owner_display": "Zero Trust Assessment",
      "category": "Identity",
      "source": "https://github.com/microsoft/zerotrustassessment"
    },
    "area_key": "entra_apps",
    "resources": {
      "apps_no_expiring_creds": {
        "id": "apps_no_expiring_creds",
        "displayName": "Apps with expired/expiring credentials",
        "testId": "apps.no_expiring_credentials"
      },
      "apps_no_implicit_grant": {
        "id": "apps_no_implicit_grant",
        "displayName": "Implicit grant disabled on apps",
        "testId": "apps.implicit_grant_disabled"
      },
      "apps_safe_redirect_uris": {
        "id": "apps_safe_redirect_uris",
        "displayName": "Safe redirect URIs",
        "testId": "apps.safe_redirect_uris"
      },
      "apps_have_owners_high_priv": {
        "id": "apps_have_owners_high_priv",
        "displayName": "High-privilege apps have owners",
        "testId": "apps.have_owners_for_high_privilege"
      },
      "apps_no_client_secrets": {
        "id": "apps_no_client_secrets",
        "displayName": "No client secrets on apps",
        "testId": "apps.no_client_secrets"
      }
    },
    "settings": [
      {
        "control_id": "zerotrust-apps:app-1",
        "title": "ZT.APP.1 - No expired or soon-expiring client credentials",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-apps:app-2",
        "title": "ZT.APP.2 - Implicit grant disabled on applications",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-apps:app-3",
        "title": "ZT.APP.3 - Redirect URIs are safe (no wildcards/http)",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-apps:app-4",
        "title": "ZT.APP.4 - High-privilege applications have owners",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-apps:app-5",
        "title": "ZT.APP.5 - No client secrets on applications",
        "recommended_value": true
      }
    ],
    "watched_keys": [],
    "name": "ZeroTrust — Application Registrations"
  },
  {
    "id": "zerotrust-auth-passwordless",
    "display_name": "ZeroTrust — Authentication Methods (Passwordless)",
    "metadata": {
      "owner": "zerotrust",
      "owner_display": "Zero Trust Assessment",
      "category": "Identity",
      "source": "https://github.com/microsoft/zerotrustassessment"
    },
    "area_key": "entra_auth_policies",
    "resources": {
      "auth_methods_policy": {
        "id": "auth_methods_policy",
        "displayName": "Authentication Methods Policy",
        "authenticationMethodConfigurations": [
          {
            "id": "Fido2",
            "state": "enabled"
          }
        ],
        "testId": "zerotrust-auth-passwordless-enabled"
      },
      "auth_sms_disabled": {
        "id": "auth_sms_disabled",
        "displayName": "SMS authentication",
        "testId": "zerotrust-auth-sms-disabled"
      },
      "auth_voice_disabled": {
        "id": "auth_voice_disabled",
        "displayName": "Voice authentication",
        "testId": "zerotrust-auth-voice-disabled"
      },
      "auth_disable_weak_mfa": {
        "id": "auth_disable_weak_mfa",
        "displayName": "Disable weak MFA (SMS/Voice)",
        "testId": "auth.disable_weak_mfa"
      },
      "auth_fido2_attestation": {
        "id": "auth_fido2_attestation",
        "displayName": "FIDO2 attestation",
        "testId": "auth.fido2_attestation_enforced"
      }
    },
    "settings": [
      {
        "control_id": "zerotrust-auth-passwordless:am-1",
        "title": "ZT.AUTH.1 - Phishing-resistant authentication methods enabled",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-auth-passwordless:am-2",
        "title": "ZT.AUTH.2 - SMS authentication disabled",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-auth-passwordless:am-3",
        "title": "ZT.AUTH.3 - Voice authentication disabled",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-auth-passwordless:am-4",
        "title": "ZT.AUTH.4 - Weak MFA (SMS/Voice) disabled",
        "recommended_value": true
      },
      {
        "control_id": "zerotrust-auth-passwordless:am-5",
        "title": "ZT.AUTH.5 - FIDO2 attestation enforced",
        "recommended_value": true
      }
    ],
    "watched_keys": [
      {
        "path": "authenticationMethodConfigurations[id=Fido2].state",
        "label": "FIDO2 state",
        "match": "equals"
      }
    ],
    "name": "ZeroTrust — Authentication Methods (Passwordless)"
  },
  {
    "id": "zerotrust-authorization-invite-policy",
    "display_name": "ZeroTrust — Guest Invite Policy",
    "metadata": {
      "owner": "zerotrust",
      "owner_display": "Zero Trust Assessment",
