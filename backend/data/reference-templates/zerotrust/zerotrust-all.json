      }
    },
    "settings": [
      {
        "control_id": "zerotrust-authorization-invite-policy:auth-1",
        "title": "ZT.AUTH.1 - Guest invite policy restricts invites to admins/guest inviters",
        "recommended_value": "adminsAndGuestInviters"
      }
    ],
    "watched_keys": [
      {
        "path": "allowInvitesFrom",
        "label": "allowInvitesFrom",
        "match": "equals"
      }
    ],
    "name": "ZeroTrust — Guest Invite Policy"
  },
  {
